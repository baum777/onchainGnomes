# X API (required for polling)
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# xAI API
XAI_API_KEY=
XAI_MODEL=grok-3
XAI_MODEL_PRIMARY=grok-3
XAI_MODEL_FALLBACKS=grok-3-mini
XAI_BASE_URL=https://api.x.ai/v1

# Replicate Image Generation
REPLICATE_API_KEY=
REPLICATE_IMAGE_MODEL=black-forest-labs/flux-schnell
REPLICATE_RUN_TIMEOUT_MS=45000
REPLICATE_DOWNLOAD_TIMEOUT_MS=20000

# OPENAI API
OPENAI_API_KEY=

# Bot Config
BOT_ACTIVATION_MODE=global
BOT_DENY_REPLY_MODE=silent
BOT_USERNAME=Gorky_on_sol
BOT_WHITELIST_USERNAMES=
BOT_WHITELIST_USER_IDS=

# Upload Optimierung
X_UPLOAD_TIMEOUT_MS=30000
X_UPLOAD_MAX_DIM=1024

# Context Engine
USE_ENHANCED_CONTEXT=true
CONTEXT_ENGINE_MODE=hybrid
CONTEXT_MAX_THREAD_DEPTH=3

# Semantic Intelligence (Phase 3)
SEMANTIC_ENABLED=true
SEMANTIC_MODE=shadow
SEMANTIC_TOPK=20

# Worker
POLL_INTERVAL_MS=30000

# App Settings
DRY_RUN=false
LOG_LEVEL=INFO
LAUNCH_MODE=dry_run

# Runtime Safety (Phase 1)
# LLM Budget Gate: Sliding window rate limiting
MAX_LLM_CALLS_PER_MINUTE=30        # Max weighted calls per minute
COST_WEIGHT_THREAD=2               # Weight for thread-mode LLM calls
COST_WEIGHT_REPLY=1                # Weight for reply-mode LLM calls

# Publish Retry Configuration
PUBLISH_RETRY_DELAYS_MS=1000,5000,15000  # Exponential backoff delays
MAX_PUBLISH_RETRIES=3              # Max retry attempts before giving up

# Polling Robustness (Phase 2)
# Backoff and Retry
FETCH_BACKOFF_BASE_MS=5000         # Initial backoff for fetch failures
FETCH_BACKOFF_MAX_MS=300000        # Max backoff (5 minutes)
FETCH_TIMEOUT_MS=30000             # HTTP timeout for fetch operations
FETCH_RETRY_JITTER_MS=500          # Random jitter added to retries

# Rate Limit Handling
RATE_LIMIT_COOLDOWN_MS=60000       # Cooldown after 429 response
ADAPTIVE_POLLING_ENABLED=true      # Adjust poll interval based on rate limits
MIN_POLL_INTERVAL_MS=5000          # Minimum poll interval
MAX_POLL_INTERVAL_MS=300000        # Maximum poll interval (5 min)

# Cursor Persistence
CURSOR_PERSISTENCE_ENABLED=true    # Persist since_id to disk/KV
CURSOR_SYNC_INTERVAL_MS=60000      # How often to sync cursor

# State Store (Phase 3)
# Use Redis for multi-worker deployments
USE_REDIS=false                    # Set to true to use Redis
REDIS_URL=redis://localhost:6379   # Redis connection URL
REDIS_KEY_PREFIX=gorky:            # Key prefix for Redis

# State TTL Configuration
EVENT_STATE_TTL_DAYS=7             # How long to keep event state
PUBLISHED_TTL_DAYS=30              # How long to keep published records
PUBLISH_LOCK_TTL_MS=30000          # TTL for publish locks
