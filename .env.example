# X API (OAuth 1.0a)
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# xAI API
XAI_API_KEY=

# Application
DEBUG=false
DRY_RUN=false
LOG_LEVEL=INFO

# Bot Activation (default: global)
# BOT_ACTIVATION_MODE=global|whitelist
# BOT_WHITELIST_USERNAMES=@twimsalot,@nirapump_
# BOT_WHITELIST_USER_IDS=  (optional: user IDs to avoid lookups)

# State
STATE_DB_PATH=state/agent_state.db

# Context-Aware Reply Engine (Gorky Persona)
MENTIONS_SOURCE=mentions
BOT_USERNAME=serGorky

# Feature flag for enhanced context (gradual migration)
USE_ENHANCED_CONTEXT=false

# Context Engine v2 migration mode: legacy | v2 | hybrid
CONTEXT_ENGINE_MODE=hybrid

# Thread context settings
CONTEXT_MAX_THREAD_DEPTH=3
CONTEXT_ENABLE_TIMELINE_SCOUT=false
CONTEXT_TIMELINE_MAX_QUERIES=2
CONTEXT_TIMELINE_TWEETS_PER_QUERY=25
CONTEXT_TIMELINE_WINDOW_MINUTES=360

# Phase 3: Semantic Intelligence (additive, disabled by default)
# Set SEMANTIC_ENABLED=true to enable; when enabled, SEMANTIC_MODE defaults to "shadow"
# SEMANTIC_ENABLED=false
# SEMANTIC_MODE=shadow
# SEMANTIC_TOPK=20
# SEMANTIC_CLUSTER_SIM=0.82
# SEMANTIC_QUERY_MAX_RESULTS=50
# SEMANTIC_MEMORY_TTL_DAYS=14
# SEMANTIC_INDEX_TTL_DAYS=7
# SEMANTIC_INDEX_MAX_DOCS=2000
# XAI_EMBEDDINGS_MODEL=embedding-grok-2
