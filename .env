# X / Twitter OAuth
X_CLIENT_ID=your_client_id
X_CLIENT_SECRET=your_client_secret
X_REFRESH_TOKEN=replace_after_oauth
# Optional: can be empty; token is refreshed automatically at runtime when needed.
X_ACCESS_TOKEN=replace_after_oauth

# LLM Provider Selection
LLM_PROVIDER=xai
LLM_FALLBACK_PROVIDER=
LLM_TIMEOUT_MS=30000
LLM_RETRY_MAX=2
LLM_MAX_TOKENS=350
LLM_TEMPERATURE=0.7

# Current Default Provider
XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL_PRIMARY=grok-3
XAI_MODEL_FALLBACKS=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# Redis / State
USE_REDIS=false
KV_URL=
REDIS_KEY_PREFIX=GNOMES_ONCHAIN:

# Runtime / Logging
POLL_INTERVAL_MS=30000
LOG_LEVEL=INFO
DRY_RUN=false

# Legacy / currently unused
# LLM_API_KEY=
# X_REDIRECT_URI=http://127.0.0.1:8080/callback
# X_OAUTH_SCOPES=tweet.read tweet.write users.read offline.access
# X_TOKEN_TYPE=bearer
# X_EXPIRES_IN=7200
# X_TOKEN_CREATED_AT=2026-03-17T22:00:00+01:00
# X_REFRESH_BUFFER_SECONDS=300
# X_BOT_USERNAME=Gnomes_onchain
# X_BOT_USER_ID=1234567890
