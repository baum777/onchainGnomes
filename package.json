{
  "name": "gorky-bot",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "demo:render": "tsx scripts/render_demo.ts",
    "poll": "tsx -r dotenv/config src/index.ts",
    "test": "vitest run",
    "test:stress": "vitest run tests/stress/personaStress.test.ts",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "js-yaml": "^4.1.0",
    "replicate": "^1.0.0",
    "sharp": "^0.33.5",
    "twitter-api-v2": "^1.15.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
